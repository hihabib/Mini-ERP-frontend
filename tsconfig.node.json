{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "composite": true,
    "outDir": ".tsbuild",
    "strict": true
  },
  "include": ["vite.config.ts", "playwright.config.ts", "tailwind.config.ts", "postcss.config.js"]
}
